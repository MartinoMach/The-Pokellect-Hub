{
  "name": "pokellect-backend",
  "version": "1.0.0",
  "description": "Azure Functions backend for Pokemon card collection",
  "main": "index.js",
  "scripts": {
    "start": "func start",
    "check:backend": "node scripts/checkBackend.js",
    "smoke:load": "node scripts/smokeLoad.js",
    "init:cosmos": "node scripts/initCosmos.js",
    "seed": "node scripts/seedDatabase.js",
    "test": "npm run check:backend && npm run smoke:load && jest",
    "test:unit": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "dependencies": {
    "@azure/cosmos": "^4.0.0",
    "@azure/functions": "^4.12.0",
    "@azure/storage-blob": "^12.31.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
